# ── Banco de Dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vivo_user:vivoRateio2024!@localhost:5432/vivo_rateio

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Autenticação ──────────────────────────────────────────────────────────────
# IMPORTANTE: troque por uma string longa e aleatória em produção
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
